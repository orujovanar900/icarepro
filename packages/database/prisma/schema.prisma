// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum OwnerType {
  FERDI_VETANDAS
  FERDI_SAHIBKAR
  HUQUQI_SEXS
}

enum ActivityLocation {
  BAKI
  DIGER
}

enum UserRole {
  SUPERADMIN
  OWNER
  MANAGER
  CASHIER
  ACCOUNTANT
  ADMINISTRATOR
  TENANT
  AGENTLIK
  AGENT
  ICARECI
}

enum ListingType {
  MENZIL
  OFIS
  OBYEKT
  HEYET_EVI
  GARAJ
  TORPAQ
  ANBAR
}

enum ListingAvailStatus {
  BOSHDUR
  BOSHALIR
  INSAAT
}

enum ListingStatus {
  PENDING
  ACTIVE
  REJECTED
  DEACTIVATED
}

enum OrgPlan {
  FREE
  PRO
  ENTERPRISE
}

enum ContractStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// Тип аренды
enum RentalType {
  RESIDENTIAL_LONG // Тип 1: долгосрочная жилая (фикс. аренда/мес)
  COMMERCIAL // Тип 2: коммерческая (базовая + % от выручки)
  RESIDENTIAL_SHORT // Тип 3: краткосрочная (посуточно)
  PARKING // Тип 4: парковочное место (дневная ставка)
  SUBLEASE // Тип 5: субаренда (дочерний контракт)
}

enum PaymentType {
  CASH
  BANK
  CARD
  ONLINE
}

enum PaymentMode {
  CALENDAR
  FIXED_DAY
}

enum DocumentType {
  CONTRACT
  ACT
  DEBT_NOTICE
  INVOICE
  RECEIPT
  ADDENDUM
  TERMINATION
  PHOTO_REPORT
  PASSPORT
  OWNERSHIP_CERT
  TEX_PASSPORT
}

enum MeterType {
  ELECTRICITY
  WATER_COLD
  WATER_HOT
  GAS
  HEAT
}

enum PropertyStatus {
  VACANT
  OCCUPIED
  UNDER_REPAIR
}

enum SubscriptionStatus {
  ACTIVE
  GRACE_PERIOD
  SUSPENDED
  CANCELLED
}

enum SubscriptionPlan {
  FREE_TRIAL
  BASHLANQIC
  PROFESSIONAL
  BIZNES
  KORPORATIV
}

// ─────────────────────────────────────────
// Models
// ─────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      OrgPlan  @default(FREE)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  subscriptionStatus   SubscriptionStatus @default(ACTIVE)
  subscriptionPlan     SubscriptionPlan   @default(FREE_TRIAL)
  planExpiresAt        DateTime?
  gracePeriodStartedAt DateTime?

  senadUstasiUsedMonth Int       @default(0)
  senadUstasiResetDate DateTime? @default(now())

  ownerType            OwnerType?
  activityLocation     ActivityLocation?
  taxVoen              String?
  isVatPayer           Boolean   @default(false)

  users         User[]
  properties    Property[]
  tenants       Tenant[]
  contracts     Contract[]
  payments      Payment[]
  expenses      Expense[]
  auditLogs     AuditLog[]
  meterReadings MeterReading[]
  listings      Listing[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  passwordHash   String
  name           String
  role           UserRole @default(MANAGER)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  telegramChatId        String?
  phone                 String?
  failedAttempts        Int       @default(0)
  lockedUntil           DateTime?
  passwordResetToken    String?
  passwordResetExpiry   DateTime?
  avatarUrl             String?
  jwtVersion            Int       @default(1)

  organization Organization @relation(fields: [organizationId], references: [id])
  payments     Payment[]
  expenses     Expense[]
  auditLogs    AuditLog[]
  tenant       Tenant?
  queueEntries QueueEntry[]
  favorites    ListingFavorite[]

  @@unique([organizationId, email])
  @@map("users")
}

model Property {
  id             String   @id @default(cuid())
  organizationId String
  number         String
  name           String
  building       String
  address        String
  area           Decimal  @db.Decimal(10, 2)
  type           String   @default("MENZEL")
  isActive       Boolean  @default(true)
  status         PropertyStatus @default(VACANT)
  lat            Decimal? @db.Decimal(10, 8)
  lng            Decimal? @db.Decimal(11, 8)
  deletedAt      DateTime?

  organization  Organization    @relation(fields: [organizationId], references: [id])
  contracts     Contract[]
  photos        PropertyPhoto[]
  meterReadings MeterReading[]
  listings      Listing[]

  @@unique([organizationId, number])
  @@map("properties")
}

model Tenant {
  id              String   @id @default(cuid())
  organizationId  String
  
  // Şəxs növü
  tenantType      String   @default("fiziki") // "fiziki" | "huquqi"
  
  // FİZİKİ ŞƏXS fields
  firstName       String?
  lastName        String?
  fatherName      String?  // Ata adı
  fin             String?  // FİZİKİ: FİN kod (7 simvol)
  passportSeries  String?  // FİZİKİ: Seriya (AA1234567)
  passportIssuedBy String? // FİZİKİ: Kim tərəfindən verilib
  passportIssuedAt DateTime?
  birthDate       DateTime?
  
  // HÜQUQİ ŞƏXS fields
  companyName     String?
  voen            String?  // HÜQUQİ: VÖEN (10 rəqəm)
  directorName    String?  // HÜQUQİ: Direktor adı
  companyAddress  String?
  bankName        String?
  bankCode        String?  // HÜQUQİ: Müxbir hesab
  iban            String?  // HÜQUQİ: IBAN
  
  // ÜMUMI fields (hər ikisi üçün)
  phone           String?
  phone2          String?  // Əlavə nömrə
  email           String?
  address         String?  // Yaşayış/qeydiyyat ünvanı
  
  // META
  notes           String?
  isBlacklisted   Boolean  @default(false)
  blacklistReason String?
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  
  userId          String?  @unique

  organization    Organization     @relation(fields: [organizationId], references: [id])
  user            User?            @relation(fields: [userId], references: [id])
  contracts       Contract[]

  @@unique([organizationId, voen])
  // NULL values are considered distinct in PostgreSQL UNIQUE, so multiple fiziki
  // tenants with fin=null are allowed, but two with the same fin in same org are not.
  @@unique([organizationId, fin])
  @@map("tenants")
}

model Contract {
  id             String         @id @default(cuid())
  organizationId String
  number         String
  propertyId     String
  tenantId       String
  rentalType     RentalType     @default(RESIDENTIAL_LONG)
  monthlyRent    Decimal        @db.Decimal(12, 2)
  startDate      DateTime       @db.Date
  endDate        DateTime       @db.Date
  status         ContractStatus @default(DRAFT)
  deletedAt      DateTime?

  // Дополнительные поля по типу аренды
  taxRate          Decimal? @db.Decimal(5, 2) // % НДС (информационно)
  depositAmount    Decimal? @db.Decimal(12, 2) // залог
  baseRent         Decimal? @db.Decimal(12, 2) // Тип 2: базовая аренда
  revenuePercent   Decimal? @db.Decimal(5, 2) // Тип 2: % от выручки
  dailyRate        Decimal? @db.Decimal(12, 2) // Тип 3/4: суточная ставка
  parentContractId String? // Тип 5: ссылка на родительский контракт
  notes            String?

  // Stage 2 Additions
  autoRenewal        Boolean  @default(false)
  isDepositReturned  Boolean  @default(false)
  lateFeePercentage  Decimal? @db.Decimal(5, 2)
  gracePeriodDays    Int?     @default(0)

  // Payment Modes
  paymentMode        PaymentMode @default(CALENDAR)
  paymentDay         Int?     // 1-31, used only for FIXED_DAY

  organization   Organization @relation(fields: [organizationId], references: [id])
  property       Property     @relation(fields: [propertyId], references: [id])
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  parentContract Contract?    @relation("subcontracts", fields: [parentContractId], references: [id])
  subContracts   Contract[]   @relation("subcontracts")
  payments       Payment[]
  documents      ContractDocument[]

  @@unique([organizationId, number])
  @@map("contracts")
}

model Payment {
  id             String      @id @default(cuid())
  organizationId String
  contractId     String
  amount         Decimal     @db.Decimal(12, 2)
  paymentDate    DateTime    @db.Date
  periodMonth    Int? // 1-12 — за какой месяц (null для посуточных)
  periodYear     Int?
  periodStart    DateTime?   @db.Date // для посуточных: заезд
  periodEnd      DateTime?   @db.Date // для посуточных: выезд
  paymentType    PaymentType
  isPenalty      Boolean     @default(false)
  penaltyNote    String?
  note           String?
  createdBy      String
  deletedAt      DateTime?

  organization  Organization @relation(fields: [organizationId], references: [id])
  contract      Contract     @relation(fields: [contractId], references: [id])
  createdByUser User         @relation(fields: [createdBy], references: [id])

  @@map("payments")
}

model Expense {
  id             String   @id @default(cuid())
  organizationId String
  amount         Decimal  @db.Decimal(12, 2)
  date           DateTime @db.Date
  category       String
  description    String?
  createdBy      String

  organization  Organization @relation(fields: [organizationId], references: [id])
  createdByUser User         @relation(fields: [createdBy], references: [id])

  @@map("expenses")
}


model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("audit_logs")
}

model MeterReading {
  id             String    @id @default(cuid())
  organizationId String
  propertyId     String
  meterType      MeterType
  readingDate    DateTime  @db.Date
  value          Decimal   @db.Decimal(12, 3)
  consumption    Decimal?  @db.Decimal(12, 3) // авто: currentValue - previousValue
  periodMonth    Int
  periodYear     Int
  note           String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])

  @@map("meter_readings")
}

model PropertyPhoto {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  caption    String?
  sortOrder  Int      @default(0)
  uploadedAt DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id])

  @@map("property_photos")
}

model ContractDocument {
  id         String    @id @default(cuid())
  contractId String
  type       String    @default("OTHER") // ACT, NOTIFICATION, ADDENDUM, INVOICE, OTHER
  title      String
  fileUrl    String
  fileName   String
  fileSize   Int
  uploadedAt DateTime  @default(now())
  uploadedBy String
  notes      String?
  deletedAt  DateTime?

  contract Contract @relation(fields: [contractId], references: [id])

  @@map("contract_documents")
}

// ─────────────────────────────────────────
// Növbəli İcarə — Listing System
// ─────────────────────────────────────────

model Listing {
  id                String    @id @default(cuid())
  organizationId    String
  propertyId        String?
  title             String
  description       String?
  type              ListingType
  district          String?
  address           String
  floor             Int?
  totalFloors       Int?
  area              Float?
  rooms             Int?
  basePrice         Float              // hidden from public responses
  availStatus       ListingAvailStatus @default(BOSHDUR)
  contractStartDate DateTime?
  contractEndDate   DateTime?
  expectedFreeDate  DateTime?
  publisherType     String?            // SAHIBI | AGENT | AGENTLIK
  publisherName     String?
  isVip             Boolean            @default(false)
  isPushed          Boolean            @default(false)
  isPanorama        Boolean            @default(false)
  status            ListingStatus      @default(PENDING)
  moderatedAt       DateTime?
  moderatedBy       String?
  rejectionReason   String?
  amenities         String[]
  photos            String[]
  lat               Float?
  lng               Float?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization  Organization    @relation(fields: [organizationId], references: [id])
  property      Property?       @relation(fields: [propertyId], references: [id])
  queueEntries  QueueEntry[]
  reports       ListingReport[]
  favorites     ListingFavorite[]

  @@index([status])
  @@index([status, deletedAt]) // composite: eliminates full scans on public marketplace queries
  @@index([district])
  @@index([type])
  @@index([availStatus])
  @@map("listings")
}

model QueueEntry {
  id            String   @id @default(cuid())
  listingId     String
  userId        String?
  fullName      String
  phone         String
  email         String?
  employStatus  String?
  persons       Int?
  hasPets       Boolean  @default(false)
  isSmoker      Boolean  @default(false)
  companyName   String?
  voen          String?
  contactPerson String?
  employeeCount Int?
  activityType  String?
  priceOffer    Float
  desiredMonths Int?
  position      Int
  status        String   @default("ACTIVE") // ACTIVE | SELECTED | WITHDRAWN | EXPIRED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([listingId])
  @@index([status])
  @@map("queue_entries")
}

model ListingReport {
  id          String   @id @default(cuid())
  listingId   String
  reporterId  String?
  reason      String
  description String?
  status      String   @default("PENDING") // PENDING | REVIEWED | RESOLVED
  createdAt   DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])

  @@map("listing_reports")
}

model ListingFavorite {
  id        String   @id @default(cuid())
  listingId String
  userId    String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([listingId, userId])
  @@index([userId])
  @@map("listing_favorites")
}
